# Puerto de la app web (http://localhost:8080)
APP_PORT=8080

# Puerto de Ollama (http://localhost:11434)
OLLAMA_PORT=11434

# Orígenes permitidos por Ollama (CORS). * vale para uso local.
OLLAMA_ORIGINS=*

# Modelos a descargar con: docker compose --profile setup run --rm ollama-models
OLLAMA_MODELS=llama3.2 qwen2.5:3b
